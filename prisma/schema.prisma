generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  passwordHash  String?
  emailVerified DateTime?
  image         String?
  globalRole    String?   // null = usuario normal · "superadmin" = admin de plataforma
  blocked       Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts               Account[]
  sessions               Session[]
  profile                UserProfile?
  messages               Message[]
  tasks                  Task[]
  rituals                RitualSession[]
  memberships            Membership[]
  channelParticipants    ChannelParticipant[]
  goals                  Goal[]
  dailyCheckIns          DailyCheckIn[]
  userMetrics            UserMetric[]
  pairMatchesAsRequester PairMatch[]          @relation("Requester")
  pairMatchesAsPartner   PairMatch[]          @relation("Partner")
  rewards                Reward[]
  feedback               Feedback[]
  joinRequests           JoinRequest[]
  learningActivities     LearningActivity[]
  surveys                Survey[]             @relation("SurveyUser")
  employeeSkills         EmployeeSkill[]      @relation("EmployeeSkillUser")
  alphaSessions          AlphaSession[]
  alphaDocuments         AlphaDocument[]
  assignedProjectTasks   ProjectTask[] @relation("ProjectTaskAssignee")
  createdProjectTasks    ProjectTask[] @relation("ProjectTaskCreator")
  notifications          Notification[]
  pushSubscriptions      PushSubscription[]
}

model UserProfile {
  id                    String   @id @default(cuid())
  userId                String   @unique
  role                  String?
  hardMoment            String?
  profileId             String?
  onboarded             Boolean  @default(false)
  tone                  String   @default("warm")
  preferredTags         String[] @default([])
  gentleCheckIns        Boolean  @default(true)
  pairStartInvites      Boolean  @default(true)
  quietMode             Boolean  @default(false)
  lastActiveWorkspaceId String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Workspace {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  hashtag     String   @unique
  description String?  @db.Text
  industry    String?
  category    String?
  emoji       String?  @default("🚀")
  teamSize    String?
  createdAt   DateTime @default(now())

  channels             Channel[]
  memberships          Membership[]
  goals                Goal[]
  templates            Template[]
  knowledgeBaseItems   KnowledgeBaseItem[]
  meetings             Meeting[]
  teamMetrics          TeamMetric[]
  methodologies        Methodology[]
  industryDatabases    IndustryDatabase[]
  subscriptions        WorkspaceSubscription[]
  joinRequests         JoinRequest[]
  feedback             Feedback[]
  smartGoal            ProjectSmartGoal?
  projectMethodologies ProjectMethodology[]
  projectKpis          ProjectKpi[]
  aiInsights           ProjectAiInsight[]
  invitations          ProjectInvitation[]
  auditLogs            AuditLog[]
  learningActivities   LearningActivity[]
  surveys              Survey[]
  employeeSkills       EmployeeSkill[]
  alphaSessions        AlphaSession[]
  alphaDocuments       AlphaDocument[]
  fiCampaigns          FeedbackCampaign[]
  fiResponses          FeedbackResponse[]
  knowledgeResources   KnowledgeResource[]
  knowledgeCategories  KnowledgeCategory[]
  knowledgeSuggestions KnowledgeSuggestion[]
  projectTasks         ProjectTask[]
}

model Membership {
  id           String    @id @default(cuid())
  userId       String
  workspaceId  String
  role         String    @default("member") // member, leader, admin (RBAC permission level)
  projectRole  String? // job title: Project Manager, Product Owner, ... (see PROJECT_ROLE_KEYS)
  status       String    @default("active") // active, invited, inactive
  photoUrl     String?
  invitedEmail String?
  seniority    String? // junior, mid, senior, lead
  hireDate     DateTime?
  joinedAt     DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId, status])
  @@index([workspaceId, projectRole])
}

model Channel {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  type        String   @default("channel") // channel, dm
  createdAt   DateTime @default(now())

  workspace    Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  messages     Message[]
  participants ChannelParticipant[]
  insights     ChannelInsight[]

  @@unique([workspaceId, name, type])
}

model ChannelParticipant {
  id        String   @id @default(cuid())
  channelId String
  userId    String
  joinedAt  DateTime @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
}

model Message {
  id        String   @id @default(cuid())
  channelId String
  userId    String
  content   String
  createdAt DateTime @default(now())
  // Thread support: null for top-level messages, parent id for replies.
  parentId  String?

  channel     Channel            @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks       Task[]
  parent      Message?           @relation("ThreadReply", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies     Message[]          @relation("ThreadReply")
  attachments MessageAttachment[]
  reactions   MessageReaction[]

  @@index([channelId, createdAt])
  @@index([parentId])
}

/// Adjunto de mensaje (archivo/imagen/documento) almacenado vía IFileStorage.
model MessageAttachment {
  id         String   @id @default(cuid())
  messageId  String
  fileName   String
  fileType   String
  storageKey String?
  url        String?  @db.Text
  mimeType   String?
  sizeBytes  Int      @default(0)
  width      Int?
  height     Int?
  createdAt  DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}

/// Reacción emoji a un mensaje (un usuario, un emoji por mensaje).
model MessageReaction {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

model Task {
  id               String    @id @default(cuid())
  messageId        String?
  userId           String
  smartGoalId      String?
  title            String
  fromQuote        String?
  category         String    @default("General")
  app              String    @default("Knowledge base")
  due              String?
  deadline         DateTime?
  load             String    @default("Light")
  micro            String
  action           String
  resource         String    @default("Untitled")
  selfMade         Boolean   @default(false)
  status           String    @default("open")
  quadrant         String? // q1, q2, q3, q4 (Eisenhower)
  estimatedMinutes Int?
  workedMinutes    Int? // minutes actually worked
  priority         Int? // 1-5
  tags             String[]  @default([])
  createdAt        DateTime  @default(now())
  completedAt      DateTime?

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message Message? @relation(fields: [messageId], references: [id], onDelete: SetNull)
  goal    Goal?    @relation(fields: [smartGoalId], references: [id], onDelete: SetNull)
}

model RitualSession {
  id               String    @id @default(cuid())
  userId           String
  taskId           String?
  feeling          String?
  moodAtStart      String?
  moodAtEnd        String?
  durationSec      Int       @default(120)
  recoveredMinutes Int?
  startedAt        DateTime?
  completedAt      DateTime?
  createdAt        DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Goal {
  id          String    @id @default(cuid())
  workspaceId String
  ownerId     String
  title       String
  specific    String?
  measurable  String?
  achievable  String?
  relevant    String?
  deadline    DateTime?
  status      String    @default("active") // active, completed, archived
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace  Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  owner      User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  milestones Milestone[]
  tasks      Task[]
}

model Milestone {
  id        String    @id @default(cuid())
  goalId    String
  title     String
  dueDate   DateTime?
  status    String    @default("pending") // pending, completed
  createdAt DateTime  @default(now())
  goal      Goal      @relation(fields: [goalId], references: [id], onDelete: Cascade)
}

model Template {
  id          String   @id @default(cuid())
  workspaceId String?
  title       String
  type        String // task, goal, meeting, retro, raci, etc.
  industry    String?
  content     String   @db.Text
  createdAt   DateTime @default(now())

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
}

model KnowledgeBaseItem {
  id               String    @id @default(cuid())
  workspaceId      String
  title            String
  content          String    @db.Text
  sourceApp        String?
  sourceUrl        String?
  validatedByLlmAt DateTime?
  createdAt        DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model Meeting {
  id          String    @id @default(cuid())
  workspaceId String
  ownerId     String
  title       String
  reason      String    @db.Text
  scheduledAt DateTime?
  status      String    @default("pending") // pending, scheduled, completed, cancelled
  createdAt   DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model DailyCheckIn {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @default(now())
  mood      String?
  energy    Int? // 1-5
  notes     String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model TeamMetric {
  id          String   @id @default(cuid())
  workspaceId String
  date        DateTime @default(now())
  type        String // mood, load_balance, procrastination_rate, deadlines_missed, recovered_minutes
  value       Float
  metadata    String?  @db.Text

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, date])
  @@index([workspaceId, type])
}

model UserMetric {
  id       String   @id @default(cuid())
  userId   String
  date     DateTime @default(now())
  type     String // recovered_minutes, rituals_completed, tasks_completed, procrastination_score
  value    Float
  metadata String?  @db.Text

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([userId, type])
}

model PairMatch {
  id           String   @id @default(cuid())
  requesterId  String
  partnerId    String
  taskId       String?
  reason       String   @db.Text
  status       String   @default("pending") // pending, approved, rejected, completed
  approvedById String?
  createdAt    DateTime @default(now())

  requester User @relation("Requester", fields: [requesterId], references: [id], onDelete: Cascade)
  partner   User @relation("Partner", fields: [partnerId], references: [id], onDelete: Cascade)
}

model Reward {
  id          String    @id @default(cuid())
  userId      String
  type        String // break, badge, recognition
  title       String
  triggeredBy String?
  claimedAt   DateTime?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Methodology {
  id          String   @id @default(cuid())
  workspaceId String
  title       String
  category    String
  content     String   @db.Text
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model IndustryDatabase {
  id          String   @id @default(cuid())
  workspaceId String?
  industry    String
  itemType    String
  data        String   @db.Text
  createdAt   DateTime @default(now())

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
}

model WorkspaceSubscription {
  id                   String    @id @default(cuid())
  workspaceId          String    @unique
  stripeCustomerId     String?
  stripeSubscriptionId String?
  plan                 String    @default("free") // free, team, business
  status               String    @default("active") // active, trialing, past_due, cancelled
  currentPeriodEnd     DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model Waitlist {
  id        String   @id @default(cuid())
  email     String   @unique
  role      String?
  teamSize  String?
  createdAt DateTime @default(now())
}

model Feedback {
  id          String   @id @default(cuid())
  workspaceId String?
  userId      String?
  type        String // win, struggle, testimonial, metric
  content     String   @db.Text
  metricValue Float?
  tags        String[] @default([])
  createdAt   DateTime @default(now())

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  user      User?      @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([workspaceId, type])
  @@index([createdAt])
}

model JoinRequest {
  id          String    @id @default(cuid())
  workspaceId String
  userId      String
  message     String?   @db.Text
  status      String    @default("pending") // pending, approved, rejected
  decidedById String?
  decidedAt   DateTime?
  createdAt   DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([status])
}

// ---------------------------------------------------------------------------
// Project Settings module
// ---------------------------------------------------------------------------

/// Objective SMART del proyecto (uno por workspace). Versionado + historial.
model ProjectSmartGoal {
  id          String    @id @default(cuid())
  workspaceId String    @unique
  title       String
  specific    String?   @db.Text
  measurable  String?   @db.Text
  achievable  String?   @db.Text
  relevant    String?   @db.Text
  timeBound   String?   @db.Text
  deadline    DateTime?
  version     Int       @default(1)
  smartScore  Float? // 0-100, completitud SMART estimada (heurística + IA)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  versions  SmartGoalVersion[]

  @@index([workspaceId])
}

/// Historial de versiones del objetivo SMART.
model SmartGoalVersion {
  id          String    @id @default(cuid())
  smartGoalId String
  version     Int
  title       String
  specific    String?   @db.Text
  measurable  String?   @db.Text
  achievable  String?   @db.Text
  relevant    String?   @db.Text
  timeBound   String?   @db.Text
  deadline    DateTime?
  smartScore  Float?
  changedById String?
  changeNote  String?
  createdAt   DateTime  @default(now())

  smartGoal ProjectSmartGoal @relation(fields: [smartGoalId], references: [id], onDelete: Cascade)

  @@index([smartGoalId, version])
}

/// Catálogo de roles (job titles) del proyecto.
model ProjectRole {
  id       String  @id @default(cuid())
  roleKey  String  @unique // project_manager, product_owner, ...
  name     String
  category String? // leadership, product, design, engineering, quality, data, stakeholder
}

/// Selección de metodología de trabajo por proyecto (1 principal + N secundarias).
model ProjectMethodology {
  id             String   @id @default(cuid())
  workspaceId    String
  methodologyKey String // agile, scrum, lean_ux, design_thinking, kanban
  tier           String   @default("secondary") // primary | secondary
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, methodologyKey])
  @@index([workspaceId, tier])
}

/// Catálogo de definiciones de KPIs.
model KpiDefinition {
  id          String @id @default(cuid())
  kpiKey      String @unique // task_completion_rate, team_velocity, ...
  name        String
  description String @db.Text
  formula     String @db.Text
  dataSource  String
  frequency   String // daily | weekly | sprint | monthly
}

/// Configuración de un KPI activado por proyecto.
model ProjectKpi {
  id             String   @id @default(cuid())
  workspaceId    String
  kpiKey         String
  enabled        Boolean  @default(true)
  target         Float?
  alertThreshold Float?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workspace Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  snapshots ProjectKpiSnapshot[]

  @@unique([workspaceId, kpiKey])
  @@index([workspaceId, enabled])
}

/// Tendencia histórica de un KPI (para visualización).
model ProjectKpiSnapshot {
  id           String   @id @default(cuid())
  projectKpiId String
  value        Float
  capturedAt   DateTime @default(now())

  projectKpi ProjectKpi @relation(fields: [projectKpiId], references: [id], onDelete: Cascade)

  @@index([projectKpiId, capturedAt])
}

/// Recomendaciones, riesgos y plan generado por la IA a partir de la configuración.
model ProjectAiInsight {
  id          String   @id @default(cuid())
  workspaceId String
  type        String // risk | recommendation | alert | action | metric | workload
  severity    String? // low | medium | high
  title       String
  detail      String   @db.Text
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, type])
  @@index([createdAt])
}

/// Invitaciones por correo a usuarios que aún no se unen (miembros pendientes).
model ProjectInvitation {
  id          String   @id @default(cuid())
  workspaceId String
  email       String
  projectRole String?
  status      String   @default("pending") // pending, accepted, revoked
  invitedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, email])
  @@index([status])
}

/// Auditoría de cambios en el módulo de configuración del proyecto.
model AuditLog {
  id          String     @id @default(cuid())
  workspaceId String?
  actorId     String?
  action      String // smart_goal.update, member.remove, kpi.toggle, ...
  entity      String // smart_goal | methodology | member | kpi | insight
  entityId    String?
  before      String?    @db.Text
  after       String?    @db.Text
  createdAt   DateTime   @default(now())
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId, entity])
  @@index([createdAt])
}

// ===== Team Insights (People Analytics) =====

model LearningActivity {
  id          String    @id @default(cuid())
  userId      String
  workspaceId String
  type        String // course, certification, workshop, reading
  title       String
  skill       String?
  level       String? // beginner, intermediate, advanced, expert
  hours       Float     @default(0)
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, completedAt])
  @@index([userId, completedAt])
  @@index([workspaceId, skill])
}

model Survey {
  id                  String   @id @default(cuid())
  userId              String
  workspaceId         String
  psychologicalSafety Int // 0-100
  sentiment           String // positive, neutral, risk
  comment             String?  @db.Text
  createdAt           DateTime @default(now())

  user      User      @relation("SurveyUser", fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@index([userId, createdAt])
}

model EmployeeSkill {
  id          String   @id @default(cuid())
  userId      String
  workspaceId String
  skill       String
  level       String // beginner, intermediate, advanced, expert
  updatedAt   DateTime @updatedAt

  user      User      @relation("EmployeeSkillUser", fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId, skill])
  @@index([workspaceId, skill])
}

// ===== Alpha Space (Espacio de Pensamiento Estratégico) =====

/// Sesión privada de pensamiento estratégico entre el líder y la IA coach.
model AlphaSession {
  id             String    @id @default(cuid())
  userId         String
  workspaceId    String
  title          String
  framework      String   @default("strategic_dialogue") // strategic_dialogue | lean_ux | decision_brief | action_plan | difficult_convo | prep_meeting | speech_practice
  challenge      String?  @db.Text // desafío principal identificado
  status         String   @default("active") // active | completed | archived
  step           Int      @default(0) // etapa del flujo guiado
  documentJson   Json? // documento ejecutivo editable en construcción
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  completedAt    DateTime?

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  messages  AlphaMessage[]
  document  AlphaDocument?

  @@index([userId, createdAt])
  @@index([workspaceId, createdAt])
}

/// Mensaje dentro de una sesión de Alpha Space.
model AlphaMessage {
  id        String   @id @default(cuid())
  sessionId String
  role      String // user | coach | system
  content   String  @db.Text
  meta      Json? // { step, field, suggestion }
  createdAt DateTime @default(now())

  session AlphaSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

/// Documento ejecutivo exportable generado/edicionable durante una sesión.
model AlphaDocument {
  id        String   @id @default(cuid())
  sessionId String   @unique
  userId    String
  workspaceId String
  title     String
  kind      String   @default("decision_brief") // lean_ux | action_plan | decision_brief | strategy | feedback_plan
  sections  Json // [{ id, label, content }]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  session   AlphaSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
}

// ===== Feedback Intelligence (Retroalimentación Anónima) =====

/// Campaña de feedback anónimo (check-in periódico o encuesta contextual).
model FeedbackCampaign {
  id          String   @id @default(cuid())
  workspaceId String
  title       String
  kind        String   @default("pulse") // pulse | onboarding | exit | contextual | 360
  questions   Json // [{ id, text, type }]
  cadence     String   @default("weekly") // weekly | monthly | ad_hoc
  status      String   @default("active") // draft | active | closed
  startsAt    DateTime?
  endsAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  responses FeedbackResponse[]

  @@index([workspaceId, status])
  @@index([workspaceId, createdAt])
}

/// Respuesta anónima a una campaña. Nunca se asocia a un usuario identificable.
model FeedbackResponse {
  id          String   @id @default(cuid())
  campaignId  String
  workspaceId String
  // userId se guarda SOLO para control de unicidad (hash/anónimo). No se muestra al líder.
  submitterHash String?
  payload     Json // { questionId -> answer } + free text
  // Métricas derivadas por la IA
  sentiment   String? // positive | neutral | risk | negative
  emotion     String? // motivated | committed | stressed | uncertain | disconnected | burned_out
  scores      Json? // { psychological_safety, engagement, trust, ... }
  createdAt   DateTime @default(now())

  campaign  FeedbackCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  workspace Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([campaignId, createdAt])
  @@index([workspaceId, sentiment])
  @@index([workspaceId, createdAt])
}


// ===== Knowledge Hub (biblioteca corporativa inteligente + RAG) =====

/// Categoría dinámica de la biblioteca de conocimiento (Marketing, Strategy, ...)
/// Las categorías por defecto se siembran con isDefault=true; las custom son isDefault=false.
model KnowledgeCategory {
  id          String   @id @default(cuid())
  workspaceId String
  key         String   // marketing, strategy, operations, ...
  name        String
  color       String?  // hex o token de color
  icon        String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  resources KnowledgeResource[]

  @@unique([workspaceId, key])
  @@index([workspaceId])
}

/// Recurso de la biblioteca corporativa. Evolución enriquecida de KnowledgeBaseItem
/// (que se mantiene para compatibilidad con el RAG básico de Mira).
model KnowledgeResource {
  id            String    @id @default(cuid())
  workspaceId   String
  categoryId    String?
  title         String
  summary       String?   @db.Text // resumen generado por IA
  contentText   String    @db.Text // texto plano extraído (para keyword search + chunks)
  fileType      String    @default("text") // text | pdf | docx | xlsx | pptx | image | video | link
  storageKey    String?   // clave en el IFileStorage (GCS / local)
  sourceUrl     String?   @db.Text
  sourceApp     String?   // slack | teams | gdrive | manual | ...
  sourceType    String    @default("manual") // manual | upload | link | capture
  authorId      String?   // sin relación fuerte (igual que AuditLog.actorId)
  projectId     String?
  accessLevel   String    @default("workspace") // workspace | leaders | members
  isPremium     Boolean   @default(false)
  tags          String[]  @default([])
  keywords      String[]  @default([]) // extraídos por IA
  status        String    @default("active") // active | processing | archived
  viewCount     Int       @default(0)
  useCount      Int       @default(0)
  aiMetadata    Json?     // { language, readingTime, confidence, topics, ... }
  version       Int       @default(1)
  createdById   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  workspace    Workspace                  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  category     KnowledgeCategory?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  chunks       KnowledgeChunk[]
  versions     KnowledgeResourceVersion[]
  suggestions  KnowledgeSuggestion[]

  @@index([workspaceId, status])
  @@index([workspaceId, categoryId])
  @@index([workspaceId, isPremium])
  @@index([workspaceId, updatedAt])
}

/// Fragmento de un recurso tras chunking. El texto vive aquí; los vectores
/// correspondientes se almacenan en el IVectorStore (in-memory dev / pgvector prod)
/// usando metadata { resourceId, chunkId, workspaceId }.
model KnowledgeChunk {
  id         String   @id @default(cuid())
  resourceId String
  ordinal    Int
  text       String   @db.Text
  tokenCount Int?
  createdAt  DateTime @default(now())

  resource KnowledgeResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@index([resourceId, ordinal])
}

/// Versionado de recursos (historial de cambios + trazabilidad).
model KnowledgeResourceVersion {
  id          String   @id @default(cuid())
  resourceId  String
  version     Int
  title       String
  contentText String   @db.Text
  summary     String?  @db.Text
  changedById String?
  changeNote  String?
  createdAt   DateTime @default(now())

  resource KnowledgeResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@index([resourceId, version])
}

/// Recomendaciones proactivas generadas por Mira a partir de actividad.
model KnowledgeSuggestion {
  id           String   @id @default(cuid())
  workspaceId  String
  resourceId   String?
  targetUserId String?
  reason       String   @db.Text
  kind         String   @default("topic_match") // topic_match | risk | gap | retrieval
  dismissed    Boolean  @default(false)
  createdAt    DateTime @default(now())

  workspace Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  resource  KnowledgeResource?  @relation(fields: [resourceId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([targetUserId, dismissed])
}

// ===== Group Chat enriquecido: insights de Mira (Wolf) por canal =====

/// Extracción analítica de Mira sobre una conversación: resumen, tareas,
/// riesgos, decisiones, acuerdos, próximos pasos. type + payload (JSON).
model ChannelInsight {
  id         String   @id @default(cuid())
  channelId  String
  workspaceId String
  type       String   // summary | tasks | risks | decisions | next_steps | retrospective | strategy | fetch
  payload    Json
  sourceMessageId String?
  createdById String?
  createdAt  DateTime @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([channelId, type, createdAt])
  @@index([workspaceId, createdAt])
}

// ===== Project Tasks (Kanban asignables por proyecto) =====

/// Tarea de proyecto asignable a un miembro. Se visualiza en tablero Kanban
/// (todo | doing | done). El líder/admin puede asignar a cualquiera; los
/// miembros crean tareas autoasignadas y pueden tomar tareas sin asignar.
model ProjectTask {
  id          String    @id @default(cuid())
  workspaceId String
  assigneeId  String? // User asignado (null = sin asignar, disponible para autoasignarse)
  createdById String
  title       String
  description String?  @db.Text
  status      String    @default("todo") // todo | doing | done
  priority    String?   // low | medium | high | urgent
  dueDate     DateTime?
  tags        String[]  @default([])
  order       Int       @default(0) // orden dentro de la columna Kanban
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  workspace  Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  assignee   User?     @relation("ProjectTaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdBy  User      @relation("ProjectTaskCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([workspaceId, status])
  @@index([workspaceId, assigneeId])
  @@index([assigneeId, status])
}

// ===== Notifications (in-app inbox + push) =====

/// Notificación persistente mostrada en la campana/centro de notificaciones.
/// El campo `type` se mapea en el cliente a texto localizado; `data` lleva
/// contexto (workspaceId, taskId, etc.) para deep-linking.
model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String // join_approved | join_rejected | task_assigned | invite_received | payment_failed | admin_action | join_request_received | dm_started
  title     String
  body      String
  data      Json?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// ===== Push subscriptions (FCM tokens por dispositivo) =====

/// Token FCM registrado por el navegador/dispositivo de un usuario.
/// Un usuario puede tener varios (varios dispositivos).
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}



