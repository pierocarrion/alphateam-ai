generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  passwordHash  String?
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  profile       UserProfile?
  messages      Message[]
  tasks         Task[]
  rituals       RitualSession[]
  memberships   Membership[]
  channelParticipants ChannelParticipant[]
  goals         Goal[]
  dailyCheckIns DailyCheckIn[]
  userMetrics   UserMetric[]
  pairMatchesAsRequester PairMatch[] @relation("Requester")
  pairMatchesAsPartner   PairMatch[] @relation("Partner")
  rewards       Reward[]
  feedback      Feedback[]
}

model UserProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  role        String?
  hardMoment  String?
  profileId   String?
  onboarded   Boolean  @default(false)
  tone        String   @default("warm")
  preferredTags String[] @default([])
  gentleCheckIns Boolean @default(true)
  pairStartInvites Boolean @default(true)
  quietMode   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())

  channels     Channel[]
  memberships  Membership[]
  goals        Goal[]
  templates    Template[]
  knowledgeBaseItems KnowledgeBaseItem[]
  meetings     Meeting[]
  teamMetrics  TeamMetric[]
  methodologies Methodology[]
  industryDatabases IndustryDatabase[]
  subscriptions WorkspaceSubscription[]
  feedback      Feedback[]
}

model Membership {
  id          String   @id @default(cuid())
  userId      String
  workspaceId String
  role        String   @default("member") // member, leader, admin
  joinedAt    DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

model Channel {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  type        String   @default("channel") // channel, dm
  createdAt   DateTime @default(now())

  workspace    Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  messages     Message[]
  participants ChannelParticipant[]

  @@unique([workspaceId, name, type])
}

model ChannelParticipant {
  id        String   @id @default(cuid())
  channelId String
  userId    String
  joinedAt  DateTime @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
}

model Message {
  id        String   @id @default(cuid())
  channelId String
  userId    String
  content   String
  createdAt DateTime @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks   Task[]
}

model Task {
  id          String    @id @default(cuid())
  messageId   String?
  userId      String
  smartGoalId String?
  title       String
  fromQuote   String?
  category    String    @default("General")
  app         String    @default("Knowledge base")
  due         String?
  deadline    DateTime?
  load        String    @default("Light")
  micro       String
  action      String
  resource    String    @default("Untitled")
  selfMade    Boolean   @default(false)
  status      String    @default("open")
  quadrant    String?   // q1, q2, q3, q4 (Eisenhower)
  estimatedMinutes Int?
  priority    Int?      // 1-5
  tags        String[]  @default([])
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message Message? @relation(fields: [messageId], references: [id], onDelete: SetNull)
  goal    Goal?    @relation(fields: [smartGoalId], references: [id], onDelete: SetNull)
}

model RitualSession {
  id          String    @id @default(cuid())
  userId      String
  taskId      String?
  feeling     String?
  moodAtStart String?
  moodAtEnd   String?
  durationSec Int       @default(120)
  recoveredMinutes Int?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Goal {
  id            String   @id @default(cuid())
  workspaceId   String
  ownerId       String
  title         String
  specific      String?
  measurable    String?
  achievable    String?
  relevant      String?
  deadline      DateTime?
  status        String   @default("active") // active, completed, archived
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace     Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  owner         User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  milestones    Milestone[]
  tasks         Task[]
}

model Milestone {
  id          String   @id @default(cuid())
  goalId      String
  title       String
  dueDate     DateTime?
  status      String   @default("pending") // pending, completed
  createdAt   DateTime @default(now())
  goal        Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
}

model Template {
  id          String   @id @default(cuid())
  workspaceId String?
  title       String
  type        String   // task, goal, meeting, retro, raci, etc.
  industry    String?
  content     String   @db.Text
  createdAt   DateTime @default(now())

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
}

model KnowledgeBaseItem {
  id               String   @id @default(cuid())
  workspaceId      String
  title            String
  content          String   @db.Text
  sourceApp        String?
  sourceUrl        String?
  validatedByLlmAt DateTime?
  createdAt        DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model Meeting {
  id          String   @id @default(cuid())
  workspaceId String
  ownerId     String
  title       String
  reason      String   @db.Text
  scheduledAt DateTime?
  status      String   @default("pending") // pending, scheduled, completed, cancelled
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model DailyCheckIn {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @default(now())
  mood      String?
  energy    Int?     // 1-5
  notes     String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model TeamMetric {
  id          String   @id @default(cuid())
  workspaceId String
  date        DateTime @default(now())
  type        String   // mood, load_balance, procrastination_rate, deadlines_missed, recovered_minutes
  value       Float
  metadata    String?  @db.Text

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, date])
  @@index([workspaceId, type])
}

model UserMetric {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @default(now())
  type      String   // recovered_minutes, rituals_completed, tasks_completed, procrastination_score
  value     Float
  metadata  String?  @db.Text

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([userId, type])
}

model PairMatch {
  id            String   @id @default(cuid())
  requesterId   String
  partnerId     String
  taskId        String?
  reason        String   @db.Text
  status        String   @default("pending") // pending, approved, rejected, completed
  approvedById  String?
  createdAt     DateTime @default(now())

  requester User @relation("Requester", fields: [requesterId], references: [id], onDelete: Cascade)
  partner   User @relation("Partner", fields: [partnerId], references: [id], onDelete: Cascade)
}

model Reward {
  id          String   @id @default(cuid())
  userId      String
  type        String   // break, badge, recognition
  title       String
  triggeredBy String?
  claimedAt   DateTime?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Methodology {
  id          String   @id @default(cuid())
  workspaceId String
  title       String
  category    String
  content     String   @db.Text
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model IndustryDatabase {
  id        String   @id @default(cuid())
  workspaceId String?
  industry  String
  itemType  String
  data      String   @db.Text
  createdAt DateTime @default(now())

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
}

model WorkspaceSubscription {
  id               String   @id @default(cuid())
  workspaceId      String   @unique
  stripeCustomerId String?
  stripeSubscriptionId String?
  plan             String   @default("free") // free, team, business
  status           String   @default("active") // active, trialing, past_due, cancelled
  currentPeriodEnd DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model Waitlist {
  id        String   @id @default(cuid())
  email     String   @unique
  role      String?
  teamSize  String?
  createdAt DateTime @default(now())
}

model Feedback {
  id          String   @id @default(cuid())
  workspaceId String?
  userId      String?
  type        String   // win, struggle, testimonial, metric
  content     String   @db.Text
  metricValue Float?
  tags        String[] @default([])
  createdAt   DateTime @default(now())

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  user      User?      @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([workspaceId, type])
  @@index([createdAt])
}
